SERVER_PORT=8080

# MongoDB (local Docker default)
MONGODB_URL=mongodb://localhost:27017/?directConnection=true

# PostgreSQL DSN (local Docker default)
POSTGRES_DSN=postgres://postgres:postgres@localhost:5432/tzone?sslmode=disable

# Redis cache (optional)
REDIS_URL=redis://localhost:6379/0

# Supabase hosted API (optional)
SUPABASE_API_URL=
SUPABASE_KEY=

# API rate limit
RATE_LIMIT_ENABLED=true
RATE_LIMIT_API_RPM=120
RATE_LIMIT_API_BURST=30
RATE_LIMIT_AUTH_RPM=20
RATE_LIMIT_AUTH_BURST=5

# Hosted examples:
# MONGODB_URL=mongodb+srv://username:password@cluster.mongodb.net/?appName=tzone
# SUPABASE_API_URL=https://your-project.supabase.co

# Backward-compatible legacy names (still supported, but deprecated):
# MONGODB_ATLAS_URL=
# SUPABASE_URL=

# JWT
JWT_SECRET=change_me_super_secret

# Google Sign-In
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
VITE_GOOGLE_CLIENT_ID=

# SMTP (required for OTP email)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=your_email@gmail.com

# MinIO object storage (Docker local defaults)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=tzone-assets
MINIO_PUBLIC_BASE_URL=http://localhost:9000
MINIO_USE_SSL=false

# Gemini AI advisor
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
AI_PHONE_DATA_PATH=phoneExample.json

